#!/bin/sh
# open-browser — Open a URL via opener TCP tunnel, with fallback to terminal output
URL="$1"
OPENER_PORT="${OPENER_PORT:-12345}"

if [ -z "$URL" ]; then
  echo "Usage: open-browser <url>" >&2
  exit 1
fi

# Send URL to opener via TCP (SSH RemoteForward)
if printf '%s' "$URL" | nc -w2 127.0.0.1 "$OPENER_PORT" 2>/dev/null; then
  exit 0
fi

# Fallback: print URL and copy to clipboard via OSC 52
echo "Open this URL in your browser:"
echo "  $URL"
printf '\033]52;c;%s\a' "$(printf '%s' "$URL" | base64)" 2>/dev/null
