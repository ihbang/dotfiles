{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(kubectl get)",
      "Bash(helm list)",
      "Read",
      "WebFetch",
      "mcp__claude_ai_Atlassian__getConfluencePageDescendants",
      "mcp__claude_ai_Atlassian__searchConfluenceUsingCql",
      "mcp__claude_ai_Atlassian__getConfluencePage",
      "Bash(ls -la /home/inhyeok/mif/norns/solver/ | grep -E \"\\\\.\\(py|yaml|json|toml\\)$\" | head -20)",
      "Bash(find /home/inhyeok/mif/norns/solver -path \"*/.venv\" -prune -o -type f -name \"*.md\" -o -name \"*.txt\" -print 2>/dev/null | grep -v \".venv\")",
      "Bash(cd /home/inhyeok/mif/norns && make lint-python 2>&1)",
      "mcp__plugin_serena_serena__list_dir",
      "Bash(find /home/inhyeok/mif/norns/tmp -type f -not -path \"*/\\\\.*\" 2>/dev/null | sort)",
      "Bash(wc -l /home/inhyeok/mif/norns/tmp/5-as/*.yaml)",
      "Bash(make test-solver:*)",
      "Bash(make lint-python:*)",
      "Bash(find /home/inhyeok/mif/norns -path \"*/helm/*\" -name \"*.yaml\" -o -path \"*/helm/*\" -name \"values.yaml\" 2>/dev/null | head -20)",
      "Bash(ls /home/inhyeok/mif/norns/tmp/test-metric-collector/2-prerequisites/isvctmpl-*.yaml)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl describe:*)",
      "WebSearch",
      "mcp__plugin_serena_serena__get_symbols_overview",
      "Bash(find /home/inhyeok/mif/norns/solver/docs -type f 2>/dev/null || echo \"no docs dir\"; find /home/inhyeok/mif/norns/docs -type f -name \"*.md\" 2>/dev/null | head -20)",
      "Bash(git checkout:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "harness@harness-marketplace": true
  },
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    }
  },
  "outputStyle": "Explanatory",
  "language": "Korean",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "docker",
      "git"
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true
}
