# Environment variables
export EDITOR=nvim

export PATH="$PATH:$HOME/.krew/bin"
export KUBECONFIG="$HOME/mif/kubeconfig.yaml"
export KUBENS=inhyeok

# LS colors
[ -x "$(command -v dircolors)" ] && eval "$(dircolors -b)"

# Cargo
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"

# Load zsh configs
for f in "${XDG_CONFIG_HOME:-$HOME/.config}/zsh"/*.zsh; do
  [ -f "$f" ] && source "$f"
done

# fzf shell integration
source <(fzf --zsh)

# zoxide
eval "$(zoxide init zsh)"

# Starship prompt
eval "$(starship init zsh)"

# bun completions
[ -s "/home/inhyeok/.bun/_bun" ] && source "/home/inhyeok/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
