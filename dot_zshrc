# Environment variables
export EDITOR=nvim

export PATH="$PATH:$HOME/.krew/bin"
export KUBECONFIG="$HOME/mif/kubeconfig.yaml"
export KUBENS=inhyeok

# LS colors
[ -x "$(command -v dircolors)" ] && eval "$(dircolors -b)"

# Cargo
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# Load zsh configs
for f in "${XDG_CONFIG_HOME:-$HOME/.config}/zsh"/*.zsh; do
  [ -f "$f" ] && source "$f"
done

# fzf shell integration
source <(fzf --zsh)

# Starship prompt
eval "$(starship init zsh)"
